// engine/debts.ts
export function updateDebts(s: GameState, dt: number, p: Params): GameState {
  const deployRate = currentDeployRate(s);
  s.res.S += (p.s0 + p.s1*deployRate*flagNoEval(s) + p.s2*s.res.A*flagAutoShip(s) - p.s3*safetySpend(s)) * (dt/1000);
  s.res.I += (p.i0 + p.i1*indeterminacy(s,p) + p.i2*syntheticShare(s) - p.i3*interpSpend(s)) * (dt/1000);
  return s;
}

export function checkIncidents(s: GameState, p: Params): GameState {
  const sensitiveGap = dot(s.cap.C, p.wSensitive) - oversightScore(s);
  if (sensitiveGap > p.incidentTau) {
    // deterministic: once per cooldown, trigger
    if (!cooldown('incident', s)) {
      s = applyIncident(s, p);
      log(s, 'INCIDENT: Forced audits, PR hit, constraints applied');
    }
  }
  return s;
}
