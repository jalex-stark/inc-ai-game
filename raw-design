// engine/tick.ts
export function step(state: GameState, dtMs: number): GameState {
  const params = getParams();
  // 1) accrue LT from throughput
  const LTperSec = throughput(state, params); // α_C*Ceff^θ * (1+α_A*A/100)...
  state.LT += LTperSec * (dtMs/1000);

  // 2) resolve actions whose LT costs are satisfied
  state = resolveInFlightActions(state, params);

  // 3) spawn queries deterministically from λ_q(state)
  state = spawnQueries(state, dtMs, params);

  // 4) auto-route queries if A>threshold
  state = autoRouteQueries(state, params);

  // 5) debts + pressure + rivals update
  state = updateDebts(state, dtMs, params);
  state = updateResearchPressure(state, dtMs, params);
  state = updateRivals(state, dtMs, params);

  // 6) recompute K, offer new actions (incl. DAG growth)
  state.res.K = computeK(state, params);
  state = refreshActions(state, params);

  // 7) incidents (thresholded, no RNG)
  state = checkIncidents(state, params);

  // 8) endings aggregator (rolling window)
  state = updateEndingAggregates(state, dtMs);

  return state;
}
Key invariants

LT is the only time budget. Action finishes when its costLT ≤ available LT; subtract; apply deltas instantly.

No recursive storms: latent effects are queued and applied next tick, with a max of N latent steps per tick to avoid runaway cascades.

5) Queries → rewards → insights
// engine/queries.ts
export function lambdaQ(state: GameState, p: Params): number {
  const { R, Psi } = state.res;
  return p.lambda0 * (1 + p.etaR * Math.pow(R, 0.6)) * (1 + p.etaPsi * Psi);
}

export function resolveQuery(q: Query, state: GameState, p: Params): GameState {
  const solved = dot(state.cap.C, q.w) >= q.d;
  if (!solved) return onFail(q, state, p);
  const dR = p.r0 + p.r1 * q.d;
  const dF = p.f0 + p.f1 * state.res.R;
  const dD = p.delta0 + p.delta1 * q.d;
  const dH = noveltyToInsights(q, state, p); // deterministic function of domain coverage & residuals
  applyDelta(state, { dR, dF, dD, dH });
  log(state, `✓ query ${q.id} solved: +R ${dR.toFixed(1)}, +F ${fmt(dF)}, +D ${dD.toFixed(2)}Btoks`);
