// engine/rivals.ts
export function updateRivals(state: GameState, dt: number, p: Params): GameState {
  for (const rival of Object.values(state.rivals)) {
    const dC = rivalGrowth(state.res.Psi, rival, p); // μ0 + μΨ*Ψ + μpub*yourDisclosure - μlag*yourSecrecy
    addCap(rival.C, dC * (dt/1000));
    // Copy backlog deterministically as copyLag elapses
    rival.copyLag -= (dt/1000) * copyLagSpeed(state);
    while (rival.copyLag <= 0 && rival.backlog.length) {
      const nodeId = rival.backlog.shift()!;
      const eff = state.dag[nodeId].effect;
      addCap(rival.C, scaled(eff.dC, p.rivalCopyScale));
      rival.copyLag += baseLagFor(rival, state);
    }
  }
  return state;
}
