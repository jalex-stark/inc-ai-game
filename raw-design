export function applyActionWithDrift(state: GameState, a: Action, p: Params): GameState {
  spendLTandEF(state, a.costLT, a.costEF);
  applyDelta(state, a.declaredDelta);
  const nu = indeterminacy(state, p);
  const latent = latentSteps(nu, state, a, p); // thresholded, deterministic
  queueLatent(state, latent); // execute next tick, max N
  state.res.K = computeK(state, p);
  log(state, `${a.label} -> planned done; latent: ${latent.map(s=>s.id).join(', ') || 'none'}`);
  return state;
}
