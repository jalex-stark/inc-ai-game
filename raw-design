// packages/narrative/director.ts
export interface Beat {
  id:string;
  predicate:(s:GameState)=>boolean;
  once?:boolean;
  write:string[]; // tokenized lines
}
export class NarrativeDirector {
  private fired = new Set<string>();
  constructor(private beats:Beat[], private tokens:Record<string,string>){}
  tick(s:GameState, emit:(line:string)=>void) {
    for (const b of this.beats) {
      if (this.fired.has(b.id) && b.once !== false) continue;
      if (b.predicate(s)) {
        b.write.forEach(w=>emit(this.render(w)));
        this.fired.add(b.id);
      }
    }
  }
  render(line:string){ return line.replace(/\$(\w+)/g,(_,k)=>this.tokens[k]||''); }
}
